# ====================================================
# EasyWay Backend – Environment Configuration Example
# ====================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/easyway

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS – frontend origin
CLIENT_ORIGIN=http://127.0.0.1:5000

# Pricing Constants
GST_DRIVER_RATE=0.05
PLATFORM_FEE_RATE=0.03
GST_PLATFORM_RATE=0.18
ADVANCE_PAYMENT_PCT=0.30

# Cancellation Penalty
CANCELLATION_PENALTY_MIN=500
CANCELLATION_PENALTY_MAX=1500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
